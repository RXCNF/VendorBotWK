# Maia API Configuration untuk Server Proxy
# Maia adalah platform pembayaran untuk akses OpenAI API
# Salin file ini ke .env dan masukkan API Key Anda
# Untuk mendapatkan API Key, hubungi info@prodlane.io atau perwakilan Maia
# Dokumentasi: https://docs.getmaia.ai

MAIA_API_KEY=your_maia_api_key_here

# Knowledge Base CSV File Path (Opsional)
# Jika tidak diset, akan menggunakan uploads/knowledge_base.csv
# CSV_FILE_PATH=./data/knowledge_base.csv

# RAG Storage Mode: 'memory' (default) atau 'tidb'
# Jika 'memory', embeddings disimpan di file JSON lokal
# Jika 'tidb', embeddings disimpan di TiDB database
RAG_STORAGE_MODE=memory

# TiDB Connection (Opsional, hanya jika RAG_STORAGE_MODE=tidb)
# TIDB_HOST=gateway01.eu-central-1.prod.aws.tidbcloud.com
# TIDB_PORT=4000
# TIDB_USER=your_tidb_user
# TIDB_PASSWORD=your_tidb_password
# TIDB_DATABASE=RAG

# Q&A Dataset CSV Path
QA_CSV_PATH=./vendor_qa_dataset.csv

